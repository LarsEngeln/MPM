<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="https://tei-c.org/release/xml/tei/custom/schema/relaxng/tei_odds.rng" type="application/xml" schematypens="http://relaxng.org/ns/structure/1.0"?>
<?xml-model href="https://tei-c.org/release/xml/tei/custom/schema/relaxng/tei_odds.rng" type="application/xml" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<tei:elementSpec ident="ornamentNote" module="mpm.core" mode="add" ns="http://www.cemfi.de/mpm/ns/1.0"
    xmlns:tei="http://www.tei-c.org/ns/1.0"
    xmlns:schematron="http://purl.oclc.org/dsdl/schematron">
    <tei:gloss>ornament note</tei:gloss>

    <tei:desc>An <tei:gi>ornamentNote</tei:gi> is a child element of <tei:gi>ornament</tei:gi> that represents a single note participating in the ornament. Its <tei:att>xml:id</tei:att> identifies the note and <tei:att>intm</tei:att> specifies its pitch interval in halftone steps. The order of <tei:gi>ornamentNote</tei:gi> children defines the order in which the notes are processed by the ornament.</tei:desc>

    <tei:classes>
        <tei:memberOf key="att.id"/>
    </tei:classes>

    <tei:content>
        <tei:empty/>
    </tei:content>

    <tei:attList>
        <tei:attDef ident="intm" usage="req">
            <tei:gloss>interval in half steps</tei:gloss>
            <tei:desc>Specifies the pitch interval of this note as a double value followed by the unit <tei:val>hs</tei:val> (half steps), e.g. <tei:val>0.0hs</tei:val> or <tei:val>-1.0hs</tei:val>.</tei:desc>
            <tei:datatype>
                <tei:dataRef name="string"/>
            </tei:datatype>
            <tei:constraintSpec ident="ornamentNote_intm_format" scheme="schematron">
                <tei:constraint>
                    <schematron:rule context="attribute::intm">
                        <schematron:assert test="matches(., '^-?[0-9]+(\.[0-9]+)?hs$')">The value of @intm must be a double followed by 'hs', e.g. '0.0hs' or '-1.0hs'.</schematron:assert>
                    </schematron:rule>
                </tei:constraint>
            </tei:constraintSpec>
        </tei:attDef>
    </tei:attList>

    <tei:exemplum>
        <egXML xmlns="http://www.tei-c.org/ns/Examples">
            <ornament date="0.0" name.ref="upper turn" note.order="#n1 #n2 #n3 #n1">
                <ornamentNote xml:id="n1" intm="1.0hs"/>
                <ornamentNote xml:id="n2" intm="0.0hs"/>
                <ornamentNote xml:id="n3" intm="-1.0hs"/>
            </ornament>
            <ornament date="720.0" name.ref="trill" note.order="|: #n1 #n2 :|">
                <ornamentNote xml:id="n1" intm="1.0hs"/>
                <ornamentNote xml:id="n2" intm="0.0hs"/>
            </ornament>
        </egXML>
    </tei:exemplum>

    <tei:remarks>
        <tei:p>When <tei:gi>ornamentNote</tei:gi> children are present they need to be referenced in the <tei:att>note.order</tei:att> attribute of the parent <tei:gi>ornament</tei:gi> element as well.</tei:p>
    </tei:remarks>
</tei:elementSpec>
